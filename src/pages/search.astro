---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import Label from "../components/Label.astro";
---

<Layout
  title="Search"
  description="Search the essays and resources on BUT. Honestly."
  noindex
>
  <Container section id="search">
    <Label>Find everything you need</Label>
    <h1 class="mt-6">Search</h1>

    <div class="post-content mt-7">
      <p>
        Searches the essays and the resources. Multiple words must all match;
        wrap them in <code>"quotes"</code> to search for an exact phrase.
      </p>
    </div>

    <form id="search-form" role="search" class="mt-8">
      <label for="search-input" class="sr-only">Search</label>
      <input
        id="search-input"
        type="search"
        name="q"
        autocomplete="off"
        placeholder="Search essays and resources…"
        class="border-line bg-background text-ink w-full border px-4 py-3 font-sans text-base"
      />
    </form>

    <p id="search-status" class="meta mt-6" aria-live="polite"></p>
    <div
      id="search-results"
      class="[&_mark]:bg-accent/15 [&_mark]:text-ink mt-2 [&_mark]:rounded-sm [&_mark]:px-0.5"
    >
    </div>
  </Container>
</Layout>

<script is:inline>
  (() => {
    const form = document.getElementById("search-form");
    const input = document.getElementById("search-input");
    const status = document.getElementById("search-status");
    const results = document.getElementById("search-results");

    let pagefind = null;
    async function getPagefind() {
      if (pagefind) return pagefind;
      try {
        // Built by the `pagefind` postbuild step into /pagefind/. Absent in
        // `astro dev` — only available after a real build.
        pagefind = await import("/pagefind/pagefind.js");
        pagefind.init();
        return pagefind;
      } catch (e) {
        status.textContent =
          "Search index isn't available here (it's generated at build time).";
        return null;
      }
    }

    const escape = (s) =>
      String(s).replace(
        /[&<>"']/g,
        (c) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[c],
      );

    async function run(query) {
      query = query.trim();
      if (!query) {
        results.innerHTML = "";
        status.textContent = "";
        return;
      }
      const pf = await getPagefind();
      if (!pf) return;
      status.textContent = "Searching…";
      const search = await pf.debouncedSearch(query);
      if (search === null) return; // superseded by a newer keystroke

      const items = await Promise.all(
        search.results.slice(0, 30).map((r) => r.data()),
      );
      const n = search.results.length;
      status.textContent = items.length
        ? `${n} result${n === 1 ? "" : "s"}`
        : "No results.";

      results.innerHTML = items
        .map(
          (d) => `
            <article class="border-line border-t py-6">
              <h2 class="text-xl leading-snug tracking-tight">
                <a href="${escape(d.url)}" class="text-ink hover:text-accent">${escape(d.meta.title || d.url)}</a>
              </h2>
              <p class="excerpt text-muted mt-2">${d.excerpt}</p>
            </article>`,
        )
        .join("");
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      run(input.value);
    });
    input.addEventListener("input", () => run(input.value));

    // Prefill + run from ?q= (so header search / shared links work).
    const q = new URLSearchParams(location.search).get("q") || "";
    if (q) input.value = q;
    input.focus();
    if (q) run(q);
  })();
</script>
