---
import Logo from "./Logo.astro";
import Nav from "./Nav.astro";
import Socials from "./Socials.astro";

import { getTags } from "../lib/wordpress.ts";

const tags = await getTags();
const tagLinks = tags.map((tag) => ({
  href: `/topic/${tag.slug}/`,
  label: tag.name,
}));

const tagLinks1 = tagLinks.filter((_, i) => i % 2 === 0);
const tagLinks2 = tagLinks.filter((_, i) => i % 2 === 1);
---

<footer id="footer" class="border-ink bg-surface text-muted border-t">
  <div
    class="mx-auto flex w-full max-w-6xl flex-wrap gap-15 px-10 py-16 focus:outline-none"
  >
    <div class="space-y flex-1 items-start space-y-6">
      <Logo />
      <p class="elegant max-w-xs text-base">
        Clarity without the comfort. Long-form essays on the messy overlap
        between humans and tech.
      </p>
      <Socials
        class="gap-5"
        linkClass="text-muted text-lg"
        links={[
          {
            href: "https://github.com/SirDarcanos",
            icon: "github",
          },
          {
            href: "https://www.linkedin.com/in/nicolamustone/",
            icon: "linkedin",
          },
          {
            href: "https://bsky.app/profile/nicolamustone.bsky.social",
            icon: "bluesky",
          },
          {
            href: "https://indieweb.social/@nicolamustone",
            icon: "mastodon",
          },
          {
            href: "https://profiles.wordpress.org/nicolamustone/",
            icon: "wordpress",
          },
          {
            href: "https://x.com/nicolamustone",
            icon: "x",
          },
        ]}
      />
    </div>
    <Nav
      links={tagLinks1}
      class="flex-col gap-2"
      linkClass="text-muted font-medium"
    />
    <Nav
      links={tagLinks2}
      class="flex-col gap-2"
      linkClass="text-muted font-medium"
    />
  </div>
  <div
    id="copyright"
    class="meta mx-auto w-full max-w-6xl items-center justify-between px-10 pb-16 text-center focus:outline-none"
  >
    <p>© 2026 But Honestly</p>
    <p class="mt-2">
      Text content licensed under CC BY-NC-SA 4.0 &middot; Code content licensed
      under GPL v2 or later &middot; Site source under MIT
    </p>
  </div>
</footer>
