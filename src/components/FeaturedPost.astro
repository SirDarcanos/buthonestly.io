---
import Image from "./Image.astro";
import ReadTime from "./ReadTime.astro";

import { type Post } from "../types.ts";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="space-y-3">
  {
    post.featuredImage ? (
      <Image
        src={post.featuredImage}
        alt={post.title}
        width={516}
        height={344}
      />
    ) : null
  }
  <p class="meta mt-6">
    <span class="text-accent">
      {
        new Date(post.date).toLocaleDateString("default", {
          day: "numeric",
          month: "long",
          year: "numeric",
        })
      }</span
    >{" "}
    &middot; <ReadTime content={post.contentHtml} />
    <h2>
      <a href={post.url} class="text-ink hover:text-accent">
        {post.title}
      </a>
    </h2>
    <p class="excerpt text-base">{post.excerpt}</p>
  </p>
</article>
