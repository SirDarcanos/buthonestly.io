---
import { Picture as AstroPicture } from "astro:assets";
import { twMerge } from "tailwind-merge";
import type { ImageMetadata } from "astro";

// Responsive image: an imported local image → Astro <Picture> with AVIF → WebP
// → JPEG. Local only; every image on the site is committed to the repo and
// re-encoded at build time.
interface Props {
  src: ImageMetadata;
  alt: string;
  width: number;
  height: number;
  widths?: number[];
  sizes?: string;
  class?: string;
  caption?: string;
  priority?: boolean;
  ariaHidden?: boolean;
}

const {
  src,
  alt,
  widths,
  sizes,
  class: className,
  caption = "",
  priority = false,
  ariaHidden = false,
} = Astro.props;

const imgClass = twMerge("block h-auto max-w-full", className);
---

<figure>
  <AstroPicture
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    formats={["avif", "webp"]}
    loading={priority ? "eager" : "lazy"}
    decoding={priority ? "auto" : "async"}
    fetchpriority={priority ? "high" : undefined}
    aria-hidden={ariaHidden ? "true" : undefined}
    class={imgClass}
  />
  {
    /* Captions are authored HTML — the credit snippet Unsplash and Pexels give
       you to copy, links and utm_ params intact. rehype-figure.mjs does the
       same for body-image captions. */
    caption && <figcaption set:html={caption} />
  }
</figure>
