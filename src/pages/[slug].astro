---
import AudioPlayer from "../components/AudioPlayer.astro";
import Divider from "../components/Divider.astro";
import Image from "../components/Image.astro";
import ReadTime from "../components/ReadTime.astro";
import SinglePost from "../layouts/SinglePost.astro";
import { getAllPosts, getRelatedPosts } from "../lib/wordpress";

import { type Post } from "../types.ts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return Promise.all(
    posts.map(async (post) => ({
      params: { slug: post.slug },
      props: {
        post,
        related: await getRelatedPosts(post, 3),
      },
    })),
  );
}

interface Props {
  post: Post;
  related: Post[];
}

const { post, related } = Astro.props;
const publishDate = new Date(post.date);
---

<SinglePost
  title={post.seo.title}
  description={post.seo.description}
  type="article"
  article={post}
>
  {/* POST META */}
  <article id={"post-" + post.id} class="post border-line mt-20 border-b pb-10">
    <header class="mb-10 space-y-6">
      <div class="flex items-center gap-3">
        <span class="label">
          {post.categories.join(", ")}
        </span>
        <Divider width={20} />
        <span class="meta"
          ><ReadTime content={post.contentHtml} suffix="min read" /></span
        >
      </div>
      <h1>{post.title}</h1>
      <p class="lead">
        {post.excerpt}
      </p>
      <div class="border-line flex border-y py-4">
        <time datetime={publishDate.toISOString()} class="label">
          {
            publishDate.toLocaleString("default", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          }
        </time>
        <p class="meta flex flex-1 justify-end">
          In {post.tags.join(", ")}
        </p>
      </div>
    </header>

    {/* FEATURED IMAGE */}
    <Image
      src={post.featuredImage!}
      alt={post.featuredImageAlt ?? ""}
      caption={post.featuredImageCaption ?? ""}
      width={1600}
      height={900}
      widths={[580, 1160]}
      sizes="(max-width: 820px) 100vw, 580px"
      class="w-full"
      priority
    />

    {/* POST CONTENT */}
    <div class="post-content mt-7" set:html={post.contentHtml} />

    <p class="meta font-bold">
      <span class="bg-accent mr-3 inline-block size-2"></span>End
    </p>
  </article>

  {/* RELATED POSTS */}
  {
    related.length > 0 && (
      <section class="my-16">
        <p class="meta mb-3">More essays like this</p>
        <ul>
          {related.map((rel) => (
            <li class="border-line flex items-start border-t py-4">
              <h3 class="flex-1">
                <a href={rel.url} class="text-ink hover:text-accent">
                  {rel.title}
                </a>
              </h3>
              <p class="meta mt-2 text-right">
                <ReadTime content={rel.contentHtml} />
              </p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <AudioPlayer />
</SinglePost>
