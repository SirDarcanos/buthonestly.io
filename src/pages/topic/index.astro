---
import Layout from "../../layouts/Layout.astro";
import TaxGrid from "../../components/TaxGrid.astro";

import { getTags } from "../../lib/essays";

const tags = await getTags();

const description =
  "Every topic covered on BUT. Honestly, from WordPress and Python to feedback and focus — a way into the writing by what you actually care about.";
---

<Layout title="Topics" description={description} type="website">
  <div
    slot="intro"
    class="flex flex-col gap-4 pt-8 md:flex-row md:items-end md:justify-between md:gap-10"
  >
    <div class="space-y-4">
      <p class="label max-w-lg text-left">Browse</p>
      <h1 class="max-w-lg">Topics</h1>
    </div>
    <p class="lead max-w-lg text-left text-lg md:text-right">
      {description}
    </p>
  </div>

  <TaxGrid terms={tags} base="topic" class="lg:grid-cols-3" />

  <div class="border-line mt-14 border-t pt-8 pb-16">
    <p class="text-muted">
      Prefer the bigger picture? Browse by <a href="/section/">section</a>, or
      read the <a href="/essays/">full archive</a> in order.
    </p>
  </div>
</Layout>
