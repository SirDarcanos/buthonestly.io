---
import Highlight from "../components/Highlight.astro";
import Layout from "../layouts/Layout.astro";
import ReadTime from "../components/ReadTime.astro";

import { getAllPosts } from "../lib/wordpress";
import { readingMinutes } from "../lib/reading-time";

const posts = await getAllPosts();
const [lead, ...rest] = posts;
const recent = rest.slice(0, 6);

const currentMonth = new Date().toLocaleString("default", {
  month: "long",
  year: "numeric",
});
---

<Layout title="BUT. Honestly" type="website">
  <div class="border-line flex items-end justify-between border-b pt-6 pb-2">
    <p class="label max-w-lg text-left">
      {currentMonth}<span class="text-muted"> &middot; New this month</span>
    </p>
    <p class="lead max-w-sm text-right text-base">
      New essays each season on leadership, programming, and the messy overlap
      between humans and tech.
    </p>
  </div>
  {lead && <Highlight post={lead} />}

  <div class="grid space-y-5 gap-x-15 md:grid-cols-2">
    {
      recent.map((post) => {
        const postDate = new Date(post.date).toLocaleString("default", {
          day: "numeric",
          month: "long",
          year: "numeric",
        });

        return (
          <div class="border-line space-y-5 border-b pb-5">
            <div class="flex justify-between">
              <p class="label text-left">
                {post.categories.join(", ")}
                <span class="text-muted font-normal"> &middot; {postDate}</span>
              </p>
              <ReadTime
                class="label text-muted text-right"
                content={post.contentHtml}
              />
            </div>
            <h2>{post.title}</h2>
            <p class="excerpt text-base">{post.excerpt}</p>
            <p class="meta font-medium">In {post.tags.join(", ")}</p>
          </div>
        );
      })
    }
  </div>
</Layout>
