---
import FeaturedPosts from "../../../components/FeaturedPosts.astro";
import Layout from "../../../layouts/Layout.astro";
import ReadTime from "../../../components/ReadTime.astro";

import { getAllPosts, getTags } from "../../../lib/essays";

import type { GetStaticPaths, Page } from "astro";
import { type Post, type Tax } from "../../../types.ts";

export const getStaticPaths = (async ({ paginate }) => {
  const [posts, tags] = await Promise.all([getAllPosts(), getTags()]);

  return tags.flatMap((tag) => {
    const tagPosts = posts.filter((post) => post.tags.includes(tag.name));
    return paginate(tagPosts, {
      params: { slug: tag.slug },
      props: { tag: tag },
      pageSize: 8,
    });
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<Post>;
  tag: Tax;
}
const { page, tag } = Astro.props;

const isFirstPage = page.currentPage === 1;
const featuredPosts = isFirstPage ? page.data.slice(0, 2) : [];
const regularPosts = isFirstPage ? page.data.slice(2) : page.data;
---

<Layout title={`${tag.name} — BUT. Honestly`} type="website">
  <div slot="intro" class="flex items-end justify-between pt-8">
    <div class="space-y-4">
      <p class="label max-w-lg text-left">Topic</p>
      <h1 class="max-w-lg">
        {tag.name}
      </h1>
    </div>
    <p class="lead max-w-lg text-right text-lg">
      {tag.description}
    </p>
  </div>

  {
    isFirstPage && (
      <FeaturedPosts
        slot="featured-posts"
        posts={featuredPosts}
        taxName={tag.name}
      />
    )
  }

  {
    /* Show the "All essays" list whenever there are non-featured posts */
    regularPosts.length > 0 && (
      <section>
        <p class="meta mb-1 font-bold">All essays</p>
        {regularPosts.map((post) => {
          const postDate = new Date(post.date).toLocaleString("default", {
            day: "numeric",
            month: "short",
            year: "numeric",
          });

          return (
            <article class="border-line flex items-center gap-10 border-t py-7">
              <div class="flex-1">
                <h3>
                  <a href={post.url} class="text-ink hover:text-accent">
                    {post.title}
                  </a>
                </h3>
                <p class="excerpt mt-3 text-base">{post.excerpt}</p>
              </div>
              <div class="meta text-right">
                <p class="text-accent">{postDate}</p>
                <ReadTime content={post.body} />
              </div>
            </article>
          );
        })}
      </section>
    )
  }

  <nav
    class="meta flex items-center justify-center gap-6 pt-8 pb-16 font-medium"
  >
    {
      page.url.prev ? (
        <a href={page.url.prev} class="text-ink hover:text-accent">
          ← Newer
        </a>
      ) : undefined
    }
    <span class="text-muted">
      Page {page.currentPage} of {page.lastPage}
    </span>
    {
      page.url.next ? (
        <a href={page.url.next} class="text-ink hover:text-accent">
          Older →
        </a>
      ) : undefined
    }
  </nav>
</Layout>
