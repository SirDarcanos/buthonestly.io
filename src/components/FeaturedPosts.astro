---
import FeaturedPost from "./FeaturedPost.astro";
import ReadTime from "./ReadTime.astro";

import { type Post } from "../types.ts";

interface Props {
  posts: Post[];
  taxName: string;
}

const { posts, taxName } = Astro.props;
---

<section
  id="featured-posts"
  class="border-line mx-auto mt-10 max-w-6xl space-y-6 border-t px-10 pt-16"
>
  <p class="meta font-bold">
    <span class="bg-accent mr-3 inline-block size-2"></span>Featured in {
      taxName
    }
  </p>
  <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
    {posts.map((post) => <FeaturedPost post={post} />)}
  </div>
</section>
