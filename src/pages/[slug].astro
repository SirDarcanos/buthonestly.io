---
import AudioPlayer from "../components/AudioPlayer.astro";
import Divider from "../components/Divider.astro";
import Downloads from "../components/Downloads.astro";
import Image from "../components/Image.astro";
import ReadTime from "../components/ReadTime.astro";
import TableOfContents from "../components/TableOfContents.astro";
import SinglePost from "../layouts/SinglePost.astro";
import { getPublishedEssays, getRelatedPosts, toPost } from "../lib/essays";

import { render, type CollectionEntry } from "astro:content";
import { type Post } from "../types.ts";

export async function getStaticPaths() {
  const entries = await getPublishedEssays();
  return Promise.all(
    entries.map(async (entry) => ({
      params: { slug: entry.id },
      props: {
        entry,
        related: await getRelatedPosts(toPost(entry), 3),
      },
    })),
  );
}

interface Props {
  entry: CollectionEntry<"essays">;
  related: Post[];
}

const { entry, related } = Astro.props;
const post = toPost(entry);
const { Content, headings } = await render(entry);
const publishDate = new Date(post.date);
---

<SinglePost
  title={post.seo.title}
  description={post.seo.description}
  type="article"
  article={post}
>
  {/* POST META */}
  <article
    id={"post-" + post.id}
    class="post border-line mt-20 border-b pb-10"
    data-pagefind-body
  >
    <header class="mb-10 space-y-6">
      <div class="flex items-center gap-3">
        <span class="label">
          {post.categories.join(", ")}
        </span>
        <Divider width={20} />
        <span class="meta"
          ><ReadTime content={post.body} suffix="min read" /></span
        >
      </div>
      <h1>{post.title}</h1>
      <p class="lead">
        {post.excerpt}
      </p>
      <div class="border-line flex border-y py-4">
        <time datetime={publishDate.toISOString()} class="label">
          {
            publishDate.toLocaleString("default", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          }
        </time>
        <p class="meta flex flex-1 justify-end">
          In {post.tags.join(", ")}
        </p>
      </div>
    </header>

    {/* FEATURED IMAGE */}
    {
      post.featuredImage && (
        <Image
          src={post.featuredImage}
          alt={post.featuredImageAlt ?? ""}
          caption={post.featuredImageCaption ?? ""}
          width={1600}
          height={900}
          widths={[580, 1160]}
          sizes="(max-width: 820px) 100vw, 580px"
          class="w-full"
          priority
        />
      )
    }

    {/* TABLE OF CONTENTS */}
    <TableOfContents headings={headings} />

    {/* POST CONTENT */}
    <div class="post-content mt-7"><Content /></div>

    <p class="meta font-bold">
      <span class="bg-accent mr-3 inline-block size-2"></span>End
    </p>
  </article>

  <Downloads downloads={entry.data.downloads} />

  {/* RELATED POSTS */}
  {
    related.length > 0 && (
      <section class="my-16">
        <p class="meta mb-3">More essays like this</p>
        <ul>
          {related.map((rel) => (
            <li class="border-line flex items-start border-t py-4">
              <h3 class="flex-1">
                <a href={rel.url} class="text-ink hover:text-accent">
                  {rel.title}
                </a>
              </h3>
              <p class="meta mt-2 text-right">
                <ReadTime content={rel.body} />
              </p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <AudioPlayer />
</SinglePost>
