---
import type { Post } from "../types.ts";
import { SITE_URL, SITE_TITLE, SITE_DESCRIPTION } from "../consts.ts";

const SITE_NAME = SITE_TITLE;
const AUTHOR_NAME = "Nicola Mustone";
const AUTHOR_URL = "https://nicolamustone.com";
const TWITTER_HANDLE = "@nicolamustone";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: "website" | "article" | "profile";
  article?: Post;
  noindex?: boolean;
  /** Extra schema.org nodes — build them with the helpers in lib/schema.ts. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  canonical = new URL(Astro.url.pathname, SITE_URL).href,
  ogImage,
  type = "website",
  article,
  noindex = false,
  jsonLd: extraJsonLd = [],
} = Astro.props;

// Google truncates around 60 characters and the suffix costs 16, so append it
// only when the title leaves room. Long titles ship unbranded, not truncated.
const TITLE_MAX = 60;
const suffix = ` — ${SITE_NAME}`;
const fullTitle =
  title === SITE_NAME
    ? SITE_NAME
    : title.length + suffix.length <= TITLE_MAX
      ? `${title}${suffix}`
      : title;
const resolvedCanonical = article?.seo.canonical ?? canonical;

// og:image is required by Open Graph; without it scrapers grab any image on the
// page. Essays have covers, everything else gets the default (`npm run og`).
const OG_FALLBACK = { src: "/og-default.png", width: 1200, height: 630 };
const essayImage = article?.seo.ogImage ?? ogImage;
const resolvedOgImage = essayImage ?? new URL(OG_FALLBACK.src, SITE_URL).href;
const ogImageAlt = essayImage
  ? (article?.featuredImageAlt ?? `${title} — ${SITE_NAME}`)
  : `${SITE_NAME} — ${SITE_DESCRIPTION}`;

const PERSON = {
  "@type": "Person",
  name: AUTHOR_NAME,
  url: AUTHOR_URL,
  sameAs: [
    "https://bsky.app/profile/nicolamustone.bsky.social",
    "https://github.com/SirDarcanos",
    "https://indieweb.social/@nicolamustone",
    "https://profiles.wordpress.org/nicolamustone/",
    "https://www.linkedin.com/in/nicolamustone/",
    "https://x.com/nicolamustone",
  ],
};

const jsonLd: Record<string, unknown>[] = [
  { "@context": "https://schema.org", ...PERSON },
];

// Homepage only — this node describes the whole site. Archives use
// CollectionPage with an isPartOf reference instead.
if (Astro.url.pathname === "/") {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
  });
}

if (type === "profile") {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    name: fullTitle,
    url: resolvedCanonical,
    mainEntity: PERSON,
  });
}

if (article) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.title,
    description: article.seo.description,
    url: article.seo.canonical,
    datePublished: article.date,
    dateModified: article.modified,
    ...(article.featuredImage ? { image: article.featuredImage } : {}),
    author: PERSON,
    publisher: PERSON,
    mainEntityOfPage: article.seo.canonical,
  });
}

jsonLd.push(...extraJsonLd);
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />
{noindex && <meta name="robots" content="noindex, follow" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:alt" content={ogImageAlt} />
{
  /* Only for the default, whose size we know. */
  !essayImage && (
    <>
      <meta property="og:image:width" content={String(OG_FALLBACK.width)} />
      <meta property="og:image:height" content={String(OG_FALLBACK.height)} />
    </>
  )
}
<meta property="og:locale" content="en_US" />
{
  article && (
    <>
      <meta property="article:published_time" content={article.date} />
      <meta property="article:modified_time" content={article.modified} />
      <meta property="article:author" content={SITE_NAME} />
    </>
  )
}

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
<meta name="twitter:site" content={TWITTER_HANDLE} />
<meta name="twitter:creator" content={TWITTER_HANDLE} />

{/* JSON-LD */}
{
  jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
