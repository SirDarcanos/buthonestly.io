{
  "name": "buthonestly-io",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "astro dev",
    "prebuild": "node scripts/generate-redirects.mjs",
    "build": "astro build",
    "related": "node scripts/build-related.mjs",
    "audio": "node scripts/build-audio.mjs",
    "images": "node scripts/optimize-images.mjs",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:links": "node scripts/check-links.mjs",
    "lint": "prettier --check . && node scripts/check-links.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "astro-icon": "^1.1.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@iconify-json/simple-icons": "^1.2.88",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
