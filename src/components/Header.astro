---
import Divider from "./Divider.astro";
import Logo from "./Logo.astro";
import Nav from "./Nav.astro";

import { getCategories } from "../lib/essays.ts";

const categories = await getCategories();
const categoryLinks = categories.map((category) => ({
  href: `/section/${category.slug}/`,
  label: category.name,
}));
// Shared by the inline desktop nav and the collapsed mobile menu.
const navLinks = [{ href: "/", label: "Home" }, ...categoryLinks];
---

<header id="header" class="mx-auto w-full max-w-6xl px-6 focus:outline-none">
  <div class="border-ink flex items-center gap-8 border-b py-5">
    <Logo priority />
    <span class="elegant hidden lg:inline-block"
      >Clarity without the comfort.</span
    >
    <Divider />
    {/* Full nav from lg up; below that it collapses into the menu button. */}
    <Nav
      class="hidden font-medium lg:flex"
      linkClass="text-muted"
      links={navLinks}
    />
    <button
      type="button"
      id="search-open"
      aria-label="Search"
      aria-haspopup="dialog"
      class="text-muted hover:text-accent flex-none cursor-pointer transition-colors"
    >
      <svg
        class="size-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
    </button>
    <button
      type="button"
      id="menu-open"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="text-muted hover:text-accent flex-none cursor-pointer transition-colors lg:hidden"
    >
      <svg
        class="size-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path id="menu-bars" d="M4 7h16M4 12h16M4 17h16"></path>
        <path id="menu-x" class="hidden" d="M6 6l12 12M18 6 6 18"></path>
      </svg>
    </button>
  </div>

  {
    /* Collapsed nav. `hidden` is toggled in JS; `lg:hidden` keeps it out of the
      way once the inline nav takes over. */
  }
  <div id="mobile-nav" class="hidden lg:hidden">
    <Nav
      class="border-line flex-col gap-4 border-b py-5"
      linkClass="text-muted"
      links={navLinks}
    />
  </div>
</header>

<div
  id="search-overlay"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
>
  <div id="search-backdrop" class="bg-ink/40 absolute inset-0 backdrop-blur-sm">
  </div>
  <div class="relative mx-auto mt-[10vh] w-full max-w-3xl px-4">
    <div class="border-line bg-background border shadow-2xl">
      <form
        id="search-form"
        role="search"
        class="border-line flex items-center gap-3 border-b px-5"
      >
        <svg
          class="text-muted size-5 flex-none"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <label for="search-input" class="sr-only">Search</label>
        <input
          id="search-input"
          type="search"
          name="q"
          autocomplete="off"
          placeholder="Search essays and resources…"
          class="text-ink placeholder:text-muted flex-1 bg-transparent py-4 font-sans text-base focus:outline-none"
        />
        <button
          type="button"
          id="search-close"
          aria-label="Close search"
          class="text-muted hover:text-ink flex-none cursor-pointer px-1 py-0.5 font-sans text-[0.65rem] font-semibold tracking-widest transition-colors"
        >
          ESC
        </button>
      </form>

      <p
        id="search-status"
        class="meta px-5 py-3 empty:hidden"
        aria-live="polite"
      >
      </p>
      <div
        id="search-results"
        class="divide-line [&_mark]:bg-accent/20 [&_mark]:text-ink max-h-[min(60vh,26rem)] divide-y overflow-y-auto empty:hidden [&_mark]:rounded-sm [&_mark]:px-0.5"
      >
      </div>
      <p
        class="text-muted border-line border-t px-5 py-3 font-sans text-xs leading-relaxed"
      >
        Multiple words must all match — wrap them in <code
          class="bg-surface rounded px-1 py-0.5 font-mono text-[0.95em]"
          >"quotes"</code
        > for an exact phrase.
      </p>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const overlay = document.getElementById("search-overlay");
    const backdrop = document.getElementById("search-backdrop");
    const openBtn = document.getElementById("search-open");
    const closeBtn = document.getElementById("search-close");
    const form = document.getElementById("search-form");
    const input = document.getElementById("search-input");
    const status = document.getElementById("search-status");
    const results = document.getElementById("search-results");

    let lastFocused = null;

    function open() {
      if (!overlay.classList.contains("hidden")) return;
      lastFocused = document.activeElement;
      overlay.classList.remove("hidden");
      document.documentElement.classList.add("overflow-hidden");
      input.focus();
      input.select();
    }

    function close() {
      if (overlay.classList.contains("hidden")) return;
      overlay.classList.add("hidden");
      document.documentElement.classList.remove("overflow-hidden");
      if (lastFocused && lastFocused.focus) lastFocused.focus();
    }

    let pagefind = null;
    async function getPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import("/pagefind/pagefind.js");
        pagefind.init();
        return pagefind;
      } catch (e) {
        status.textContent =
          "Search index isn't available here (it's generated at build time).";
        return null;
      }
    }

    const escape = (s) =>
      String(s).replace(
        /[&<>"']/g,
        (c) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[c],
      );

    const MIN_QUERY = 3;
    async function run(query) {
      query = query.trim();
      if (query.length < MIN_QUERY) {
        results.innerHTML = "";
        selected = -1;
        status.textContent = query
          ? `Type at least ${MIN_QUERY} characters.`
          : "";
        return;
      }
      const pf = await getPagefind();
      if (!pf) return;
      status.textContent = "Searching…";
      const search = await pf.debouncedSearch(query);
      if (search === null) return; // superseded by a newer keystroke

      const raw = await Promise.all(
        search.results.slice(0, 30).map((r) => r.data()),
      );

      // Pagefind falls back to matching a short prefix of the query (so
      // "awdjkawjdk" matches "aw" in "_is_aw_coupon"). Keep only results where a
      // query term is a genuine prefix of, or stem of, an actually-matched word
      // (the <mark>s in the excerpt) — dropping that character-by-character noise.
      const terms = query
        .toLowerCase()
        .split(/[^a-z0-9]+/i)
        .filter((t) => t.length >= MIN_QUERY);
      const wholeWord = (d) => {
        if (!terms.length) return true;
        const tokens = [...String(d.excerpt).matchAll(/<mark>(.*?)<\/mark>/gis)]
          .flatMap((m) => m[1].toLowerCase().split(/[^a-z0-9]+/i))
          .filter(Boolean);
        return terms.some((t) =>
          tokens.some(
            (tok) =>
              tok.length >= MIN_QUERY &&
              // The matched word must start with the query term (real prefix
              // search, e.g. "coup" -> "coupon"), or be at most a two-char stem
              // shorter (plurals, e.g. "coupons" -> "coupon"). Anything looser
              // lets a short indexed word ("ada") match long gibberish
              // ("adadawdwdad") via Pagefind's prefix-truncation fallback.
              (tok.startsWith(t) ||
                (t.startsWith(tok) && t.length - tok.length <= 2)),
          ),
        );
      };
      const items = raw.filter(wholeWord);

      // Show the true total only when nothing was filtered out; otherwise the
      // filtered count (the real total past the first 30 is unknown).
      const total =
        items.length === raw.length ? search.results.length : items.length;
      status.textContent = items.length
        ? `${total} result${total === 1 ? "" : "s"}`
        : "No results.";

      results.innerHTML = items
        .map(
          (d) => `
            <a href="${escape(d.url)}" data-result class="block px-5 py-4 transition-colors hover:bg-surface aria-selected:bg-surface" role="option">
              <h2 class="text-ink text-lg leading-snug tracking-tight">${escape(d.meta.title || d.url)}</h2>
              <p class="excerpt text-muted mt-1.5 line-clamp-2">${d.excerpt}</p>
            </a>`,
        )
        .join("");
      selected = items.length ? 0 : -1;
      highlight(false);
    }

    // Keyboard selection across the rendered results (command-palette style).
    let selected = -1;
    function rows() {
      return [...results.querySelectorAll("[data-result]")];
    }
    function highlight(scroll) {
      rows().forEach((el, i) => {
        const on = i === selected;
        el.setAttribute("aria-selected", on ? "true" : "false");
        if (on && scroll) el.scrollIntoView({ block: "nearest" });
      });
    }
    function move(delta) {
      const n = rows().length;
      if (!n) return;
      selected = (selected + delta + n) % n;
      highlight(true);
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      run(input.value);
      // Inline script — call Fathom directly (can't import the track() helper).
      if (input.value.trim()) window.fathom?.trackEvent?.("Search");
    });
    input.addEventListener("input", () => run(input.value));
    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        move(1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        move(-1);
      } else if (e.key === "Enter") {
        const el = rows()[selected];
        if (el) {
          e.preventDefault();
          window.location.href = el.getAttribute("href");
        }
      }
    });

    openBtn.addEventListener("click", open);
    closeBtn.addEventListener("click", close);
    backdrop.addEventListener("click", close);

    document.addEventListener("keydown", (e) => {
      // Cmd/Ctrl+K toggles the overlay from anywhere.
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        overlay.classList.contains("hidden") ? open() : close();
        return;
      }
      if (e.key === "Escape" && !overlay.classList.contains("hidden")) {
        close();
        return;
      }
      // "/" opens search unless the user is typing in a field.
      const tag = (e.target.tagName || "").toLowerCase();
      const typing =
        tag === "input" || tag === "textarea" || e.target.isContentEditable;
      if (e.key === "/" && !typing && overlay.classList.contains("hidden")) {
        e.preventDefault();
        open();
      }
    });
  })();

  /* Collapsed nav toggle (below md). */
  (function () {
    const btn = document.getElementById("menu-open");
    const nav = document.getElementById("mobile-nav");
    if (!btn || !nav) return;
    const bars = document.getElementById("menu-bars");
    const ex = document.getElementById("menu-x");

    function setOpen(open) {
      nav.classList.toggle("hidden", !open);
      bars.classList.toggle("hidden", open);
      ex.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    }

    btn.addEventListener("click", () =>
      setOpen(nav.classList.contains("hidden")),
    );
    // Following a link should leave the menu closed behind you.
    nav.addEventListener("click", (e) => {
      if (e.target.closest("a")) setOpen(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !nav.classList.contains("hidden")) {
        setOpen(false);
        btn.focus();
      }
    });
  })();
</script>
