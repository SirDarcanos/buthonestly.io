---
import AudioPlayer from "../components/AudioPlayer.astro";
import Divider from "../components/Divider.astro";
import Downloads from "../components/Downloads.astro";
import Newsletter from "../components/Newsletter.astro";
import Picture from "../components/Picture.astro";
import ReadTime from "../components/ReadTime.astro";
import TableOfContents from "../components/TableOfContents.astro";
import TaxLinks from "../components/TaxLinks.astro";
import SinglePost from "../layouts/SinglePost.astro";
import { getPublishedEssays, getRelatedPosts, toPost } from "../lib/essays";
import { breadcrumbList } from "../lib/schema.ts";
import { taxUrl } from "../taxonomies.ts";

import { render, type CollectionEntry } from "astro:content";
import { type Post } from "../types.ts";

export async function getStaticPaths() {
  const entries = await getPublishedEssays();
  return Promise.all(
    entries.map(async (entry) => ({
      params: { slug: entry.id },
      props: {
        entry,
        related: await getRelatedPosts(toPost(entry), 6),
      },
    })),
  );
}

interface Props {
  entry: CollectionEntry<"essays">;
  related: Post[];
}

const { entry, related } = Astro.props;
const post = toPost(entry);
const { Content, headings } = await render(entry);
const publishDate = new Date(post.date);

// Trail through the essay's first section, so search results show
// "buthonestly.io › Sections › Leadership" instead of a bare URL.
const primarySection = post.categories[0];
const jsonLd = [
  breadcrumbList([
    { name: "Sections", path: "/section/" },
    ...(primarySection
      ? [{ name: primarySection, path: taxUrl("section", primarySection) }]
      : []),
    { name: post.title },
  ]),
];
---

<SinglePost
  title={post.seo.title}
  description={post.seo.description}
  type="article"
  article={post}
  jsonLd={jsonLd}
>
  {/* POST META */}
  <article
    id={"post-" + post.id}
    class="post border-line mt-20 border-b pb-10"
    data-pagefind-body
  >
    <header class="mb-10 space-y-6">
      <div class="flex items-center gap-3">
        <span class="label">
          <TaxLinks names={post.categories} base="section" />
        </span>
        <Divider width={20} />
        <span class="meta"
          ><ReadTime content={post.body} suffix="min read" /></span
        >
      </div>
      <h1>{post.title}</h1>
      <p class="lead">
        {post.excerpt}
      </p>
      <div class="border-line flex border-y py-4">
        <time datetime={publishDate.toISOString()} class="label">
          {
            publishDate.toLocaleString("default", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          }
        </time>
        <p class="meta flex-1 justify-end text-right">
          In <TaxLinks names={post.tags} base="topic" />
        </p>
      </div>
    </header>

    {/* FEATURED IMAGE */}
    {
      post.cover && (
        <Picture
          src={post.cover}
          alt={post.featuredImageAlt ?? ""}
          caption={post.featuredImageCaption ?? ""}
          width={1600}
          height={900}
          widths={[580, 768, 960, 1160, 1376]}
          sizes="(max-width: 820px) 100vw, 580px"
          class="w-full"
          priority
        />
      )
    }

    {/* TABLE OF CONTENTS */}
    <TableOfContents headings={headings} />

    {/* POST CONTENT */}
    <div class="post-content mt-7"><Content /></div>

    <p class="meta font-bold">
      <span class="bg-accent mr-3 inline-block size-2"></span>End
    </p>
  </article>

  <Downloads downloads={entry.data.downloads} />

  {/* RELATED POSTS */}
  {
    related.length > 0 && (
      <section class="my-16">
        <p class="meta mb-3">More similar essays</p>
        <ul>
          {related.map((rel) => (
            <li class="border-line border-t py-4">
              {/* Stacked rows on narrow screens — side by side the read time
                  steals width and forces the title to wrap early. */}
              <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:gap-4">
                <h3 class="flex-1">
                  <a
                    href={rel.url}
                    class="text-ink hover:text-accent"
                    data-track="Related post click"
                  >
                    {rel.title}
                  </a>
                </h3>
                <p class="meta flex-none sm:mt-2 sm:text-right">
                  <ReadTime content={rel.body} />
                </p>
              </div>
              <p class="excerpt">{rel.excerpt}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <Newsletter />

  <AudioPlayer />
</SinglePost>
