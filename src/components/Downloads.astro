---
import Button from "./Button.astro";
import { DOWNLOADS_BASE } from "../lib/cdn.mjs";

// Renders an essay's `downloads` front-matter as button links (files served
// directly from R2 at <DOWNLOADS_BASE>/<file>).
interface DownloadItem {
  file: string;
  label?: string;
}
interface Props {
  downloads?: DownloadItem[];
}
const { downloads } = Astro.props;
const ext = (file: string) => file.split(".").pop()?.toUpperCase() ?? "FILE";
---

{
  downloads && downloads.length > 0 && (
    <section class="my-12">
      <p class="meta font-bold">
        <span class="bg-accent mr-3 inline-block size-2" />
        Downloads
      </p>
      <ul class="mt-4 flex flex-col gap-3">
        {downloads.map((d) => (
          <li>
            <Button
              href={`${DOWNLOADS_BASE}/${d.file}`}
              download
              icon="download"
              badges={[ext(d.file)]}
              data-track={`Download: ${d.file}`}
            >
              {d.label ?? d.file}
            </Button>
          </li>
        ))}
      </ul>
    </section>
  )
}
