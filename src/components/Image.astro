---
import { twMerge } from "tailwind-merge";

interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  priority?: boolean;
  ariaHidden?: boolean;
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  priority = false,
  ariaHidden = false,
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  loading={priority ? "eager" : "lazy"}
  decoding={priority ? "auto" : "async"}
  aria-hidden={ariaHidden ? "true" : undefined}
  class={twMerge("block h-auto max-w-full", className)}
/>
