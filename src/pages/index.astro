---
import Highlight from "../components/Highlight.astro";
import Home from "../layouts/Home.astro";
import Label from "../components/Label.astro";
import ReadTime from "../components/ReadTime.astro";
import { getAllPosts } from "../lib/essays";

const posts = await getAllPosts();
const [lead, ...rest] = posts;
const recent = rest.slice(1, 7);

const currentMonth = new Date().toLocaleString("default", {
  month: "long",
  year: "numeric",
});
---

<Home title="BUT. Honestly" type="website">
  <div slot="intro" class="flex items-end justify-between pt-8">
    <div class="space-y-4">
      <p class="label max-w-lg text-left">{currentMonth}</p>
      <h1 class="max-w-lg">New This Month</h1>
    </div>
    <p class="lead max-w-sm text-right text-lg">
      New essays each month on leadership, programming, and the messy overlap
      between humans and tech.
    </p>
  </div>

  {lead && <Highlight slot="highlight" post={lead} />}

  <section class="grid gap-x-12 pb-16 md:grid-cols-2">
    {
      recent.map((post) => {
        const postDate = new Date(post.date).toLocaleString("default", {
          day: "numeric",
          month: "long",
          year: "numeric",
        });

        return (
          <article class="border-line space-y-3 border-b py-6 nth-last-[-n+2]:border-0">
            <div class="flex justify-between">
              <p class="label text-left">{post.categories.join(", ")}</p>
              <div class="meta flex gap-2">
                <p>{postDate}</p> &middot;
                <ReadTime content={post.body} />
              </div>
            </div>
            <h3>
              <a href={post.url}>{post.title}</a>
            </h3>
            <p class="excerpt text-base">{post.excerpt}</p>
          </article>
        );
      })
    }
  </section>

  <section class="border-line border-t py-16">
    <Label>Beyond the essays</Label>
    <h2 class="mt-3">Downloads & Tools</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <a
        href="/resources/"
        class="border-line bg-surface hover:border-accent group block border p-8 transition-colors"
      >
        <h3 class="group-hover:text-accent text-xl transition-colors">
          Resources &amp; Assets
        </h3>
        <p class="excerpt text-muted mt-2">
          Templates, notebooks, datasets, and small tools I make and use myself
          — free, no email gates.
        </p>
      </a>
      <a
        href="/resources/free-ai-voice-generator/"
        class="border-line bg-surface hover:border-accent group block border p-8 transition-colors"
      >
        <h3 class="group-hover:text-accent text-xl transition-colors">
          Free AI Voice Generator
        </h3>
        <p class="excerpt text-muted mt-2">
          Turn any text into natural speech, right in your browser — nothing you
          type ever leaves your device.
        </p>
      </a>
    </div>
  </section>
</Home>
