---
import FeaturedPosts from "../../../components/FeaturedPosts.astro";
import Layout from "../../../layouts/Layout.astro";
import ReadTime from "../../../components/ReadTime.astro";

import TaxCrossLinks from "../../../components/TaxCrossLinks.astro";

import {
  coOccurringTax,
  getAllPosts,
  getCategories,
} from "../../../lib/essays";
import { paginatedDescription, paginatedTitle } from "../../../lib/seo.ts";
import { breadcrumbList, collectionPage } from "../../../lib/schema.ts";

import type { GetStaticPaths, Page } from "astro";
import { type Post, type Tax } from "../../../types.ts";

export const getStaticPaths = (async ({ paginate }) => {
  const [posts, categories] = await Promise.all([
    getAllPosts(),
    getCategories(),
  ]);

  return categories.flatMap((category) => {
    const inCategory = posts.filter((post) =>
      post.categories.includes(category.name),
    );
    const sticky = inCategory.filter((post) => post.sticky);
    const regular = inCategory.filter((post) => !post.sticky);
    // Topics carried by this section's essays, most common first. The tail is
    // long and thin (a topic on one essay isn't characteristic), so cap it.
    const topics = coOccurringTax(inCategory, (post) => post.tags).slice(0, 6);
    return paginate(regular, {
      params: { slug: category.slug },
      props: { category, sticky, topics },
      pageSize: 8,
    });
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<Post>;
  category: Tax;
  sticky: Post[];
  topics: Tax[];
}
const { page, category, sticky, topics } = Astro.props;

const isFirstPage = page.currentPage === 1;
const featuredPosts = isFirstPage ? sticky : [];
const regularPosts = page.data;

// Sticky essays are lifted out of the paginated list and shown on page 1 only,
// so they sit ahead of everything in the ItemList but aren't counted in
// `page.start`. Offset page 2+ past them, or positions overlap page 1's.
const listItems = isFirstPage
  ? [...featuredPosts, ...regularPosts]
  : regularPosts;
const listStart = isFirstPage ? 0 : sticky.length + page.start;

const jsonLd = [
  breadcrumbList([
    { name: "Sections", path: "/section/" },
    { name: category.name },
  ]),
  collectionPage({
    name: category.name,
    description: category.description,
    url: Astro.url.pathname,
    items: listItems,
    startIndex: listStart,
  }),
];
---

<Layout
  title={paginatedTitle(category.name, page)}
  description={paginatedDescription(category.description, page)}
  type="website"
  jsonLd={jsonLd}
>
  <div
    slot="intro"
    class="flex flex-col gap-4 pt-8 md:flex-row md:items-end md:justify-between md:gap-10"
  >
    <div class="space-y-4">
      <p class="label max-w-lg text-left">Section</p>
      <h1 class="max-w-lg">
        {category.name}
      </h1>
    </div>
    {
      category.description && (
        <p class="lead max-w-lg text-left text-lg md:text-right">
          {category.description}
        </p>
      )
    }
  </div>

  {
    isFirstPage && featuredPosts.length > 0 && (
      <FeaturedPosts
        slot="featured-posts"
        posts={featuredPosts}
        taxName={category.name}
      />
    )
  }

  {
    /* Show the "All essays" list whenever there are non-featured posts */
    regularPosts.length > 0 && (
      <section>
        <p class="meta mb-1 font-bold">All essays</p>
        {regularPosts.map((post) => {
          const postDate = new Date(post.date).toLocaleString("default", {
            day: "numeric",
            month: "short",
            year: "numeric",
          });

          // Meta leads on mobile — date left, read time right — matching the
          // home cards. From sm it moves back beside the title as a right-hand
          // column, hence the order swap.
          return (
            <article class="border-line flex flex-col gap-3 border-t py-7 sm:flex-row sm:items-center sm:gap-10">
              <div class="meta flex items-center justify-between gap-4 sm:order-2 sm:flex-none sm:flex-col sm:items-end sm:gap-0 sm:text-right">
                <p class="text-accent">{postDate}</p>
                <ReadTime content={post.body} />
              </div>
              <div class="sm:order-1 sm:flex-1">
                <h3>
                  <a href={post.url} class="text-ink hover:text-accent">
                    {post.title}
                  </a>
                </h3>
                <p class="excerpt mt-3 text-base">{post.excerpt}</p>
              </div>
            </article>
          );
        })}
      </section>
    )
  }

  <nav
    class="meta flex items-center justify-center gap-6 pt-8 pb-10 font-medium"
  >
    {
      page.url.prev ? (
        <a href={page.url.prev} class="text-ink hover:text-accent">
          ← Newer
        </a>
      ) : undefined
    }
    <span class="text-muted">
      Page {page.currentPage} of {page.lastPage}
    </span>
    {
      page.url.next ? (
        <a href={page.url.next} class="text-ink hover:text-accent">
          Older →
        </a>
      ) : undefined
    }
  </nav>

  <TaxCrossLinks
    heading={`Topics in ${category.name}`}
    terms={topics}
    base="topic"
  />
</Layout>
