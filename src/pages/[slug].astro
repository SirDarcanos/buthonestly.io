---
import Highlight from "../components/Highlight.astro";
import Layout from "../layouts/Layout.astro";
import { getAllPosts } from "../lib/wordpress";

import { type Post, type PostLink } from "../types.ts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: {
        title: posts[(i - 1 + posts.length) % posts.length].title,
        slug: posts[(i - 1 + posts.length) % posts.length].slug,
      },
      next: {
        title: posts[(i + 1) % posts.length].title,
        slug: posts[(i + 1) % posts.length].slug,
      },
    },
  }));
}

interface Props {
  post: Post;
  prev: PostLink;
  next: PostLink;
}

const { post, prev, next } = Astro.props;
const publishDate = new Date(post.date);
---

<Layout
  title={post.seo.title}
  description={post.seo.description}
  type="article"
  article={post}
>
  {/* POST HEADER */}
  <article id={"post-" + post.id} class="mt-20">
    <header class="text-center md:max-w-xl md:text-left">
      <p class="font-mono text-sm uppercase">
        {
          post.tags.map((tag) => (
            <>
              <span class="text-accent">{tag}</span>
              <span class="text-faint"> / </span>
            </>
          ))
        }
        <time datetime={post.date} class="text-faint">
          {
            publishDate.toLocaleDateString("en-RO", {
              year: "numeric",
              month: "short",
            })
          }
        </time>
        {
          post.categories.map((category) => (
            <span class="bg-accent-soft text-accent ml-2 inline-block px-2 py-1 align-middle font-mono text-xs font-light uppercase">
              {category}
            </span>
          ))
        }
      </p>
      <h1 class="mt-3 mb-10 text-4xl">{post.title}</h1>
      <p class="text-muted mt-4 text-xl">
        {post.excerpt}
      </p>
    </header>

    {/* POST CONTENT */}
    <div class="post-content mt-7" set:html={post.contentHtml} />
  </article>
</Layout>
