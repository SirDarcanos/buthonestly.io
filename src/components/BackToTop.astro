<button
  id="back-to-top"
  type="button"
  aria-label="Back to top"
  class="border-line bg-surface text-muted hover:text-accent fixed right-5 bottom-5 z-40 hidden cursor-pointer rounded-full border p-2.5 shadow-sm transition-colors"
>
  {/* Arrow up */}
  <svg
    class="size-5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.7"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18"></path>
  </svg>
</button>

<script>
  function init(): void {
    const btn = document.getElementById("back-to-top");
    if (!btn) return;

    // Show once the reader has scrolled a viewport past the top.
    const toggle = () => {
      btn.classList.toggle("hidden", window.scrollY < window.innerHeight);
    };
    toggle();
    window.addEventListener("scroll", toggle, { passive: true });

    btn.addEventListener("click", () => {
      const reduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      // Hand focus back to the top of the page for keyboard users — before
      // scrolling, as focus() aborts an in-flight smooth scroll.
      document.getElementById("main")?.focus({ preventScroll: true });
      window.scrollTo({ top: 0, behavior: reduced ? "auto" : "smooth" });
    });
  }

  init();
  // Re-run if the site ever adopts Astro view transitions.
  document.addEventListener("astro:page-load", init);
</script>
