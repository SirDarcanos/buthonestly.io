---
import Head from "../components/Head.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import { type Post } from "../types.ts";

interface Props {
  title: string;
  description?: string;
  type?: "website" | "article" | "profile";
  article?: Post;
  noindex?: boolean;
}

const { title, description, type, article, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <Head
    title={title}
    description={description}
    type={type}
    article={article}
    noindex={noindex}
  />
  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="border-line bg-surface text-ink sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:border focus:px-4 focus:py-2 focus:text-sm"
    >
      Skip to main content
    </a>

    {/* HEADER */}
    <Header />

    <main
      id="main"
      tabindex="-1"
      class="mx-auto w-full max-w-2xl flex-1 px-10 focus:outline-none"
    >
      <slot />
    </main>

    {/* FOOTER */}
    <Footer />
  </body>
</html>
