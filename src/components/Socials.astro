---
import { Icon } from "astro-icon/components";
import { twMerge } from "tailwind-merge";

interface NavLink {
  href: string;
  icon: string;
}

interface Props {
  links: NavLink[];
  class?: string;
  linkClass?: string;
}

const { links: links, class: className, linkClass } = Astro.props;

const path = Astro.url.pathname;
---

<nav class={twMerge("meta flex gap-6", className)}>
  {
    links.map((link) => (
      <a
        href={link.href}
        target="_blank"
        class={twMerge(
          "text-ink hover:text-accent transition-colors aria-[current=page]:font-semibold",
          linkClass,
        )}
      >
        <Icon name=`simple-icons:${link.icon}` />
      </a>
    ))
  }
</nav>
