---
import Head from "../components/Head.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";

import { type Post } from "../types.ts";

interface Props {
  title: string;
  description?: string;
  type?: "website" | "article" | "profile";
  article?: Post;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, type, article, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <Head
    title={title}
    description={description}
    type={type}
    article={article}
    noindex={noindex}
    jsonLd={jsonLd}
  />
  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="border-line bg-surface text-ink sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:border focus:px-4 focus:py-2 focus:text-sm"
    >
      Skip to main content
    </a>

    {/* HEADER */}
    <Header />

    {
      Astro.slots.has("intro") && (
        <div class="mx-auto w-full max-w-6xl px-6 md:px-10">
          <slot name="intro" />
        </div>
      )
    }

    <slot name="highlight" />

    <main
      id="main"
      tabindex="-1"
      class="mx-auto w-full max-w-6xl flex-1 px-6 focus:outline-none md:px-10"
    >
      <slot />
    </main>

    {/* FOOTER */}
    <Footer />

    <BackToTop />
  </body>
</html>
