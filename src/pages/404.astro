---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import ReadTime from "../components/ReadTime.astro";
import { getAllPosts } from "../lib/essays";

const suggestions = (await getAllPosts()).slice(0, 3);
---

<Layout title="Page not found" noindex>
  <Container section id="not-found" className="md:max-w-2xl">
    <p class="label text-center">Error 404 — Page not found</p>

    <p
      class="text-accent mt-4 text-center font-serif text-[7rem] leading-none font-light italic md:text-[10rem]"
    >
      404
    </p>

    <h1 class="mt-8 text-center">This page, honestly, isn't here.</h1>
    <p class="text-muted mx-auto mt-5 max-w-md text-center text-lg">
      The link may have moved, been retired, or never existed. No confident
      guessing here — just a few essays that are definitely real.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/essays/"
        class="bg-ink text-background hover:bg-accent flex items-center gap-2 px-6 py-3 font-sans text-sm font-semibold tracking-wide transition-colors"
      >
        ← Back to essays
      </a>
      <a
        href="/"
        class="border-line text-ink hover:border-accent hover:text-accent border px-6 py-3 font-sans text-sm font-semibold tracking-wide transition-colors"
      >
        Browse a topic
      </a>
    </div>

    <section class="mt-20">
      <p class="label text-center">Perhaps you were looking for</p>
      <div class="mt-6">
        {
          suggestions.map((post) => (
            <article class="border-line flex items-center justify-between gap-6 border-t py-6">
              <h3 class="text-2xl leading-snug tracking-tight">
                <a href={post.url} class="text-ink hover:text-accent">
                  {post.title}
                </a>
              </h3>
              <p class="meta flex-none text-right">
                {post.categories[0]} &middot; <ReadTime content={post.body} />
              </p>
            </article>
          ))
        }
      </div>
    </section>
  </Container>
</Layout>

<script>
  // A static page can't know the 404'd path server-side.
  if (typeof location !== "undefined") {
    console.info(`404 — no page at ${location.pathname}`);
  }
</script>
