---
import Label from "./Label.astro";

// Custom form posting to Kit (form 9685650). The markup is ours so it matches
// the palette; submission is AJAX so the visitor stays on the page. Kit sends
// the confirmation email (double opt-in) after a successful post.
//
// `inline` puts the copy and form side by side (used on the wide home page);
// the default stacks them, which fits the narrow essay reading column.
interface Props {
  inline?: boolean;
}
const { inline = false } = Astro.props;
---

<section class="border-line border-t py-16">
  <div
    class:list={[
      "border-line bg-surface border p-8 md:p-12",
      inline && "md:flex md:items-center md:justify-between md:gap-10",
    ]}
  >
    <div class:list={[inline && "md:max-w-sm"]}>
      <Label>Newsletter</Label>
      <h2 class="mt-3">Stay in the loop</h2>
      <p class="text-muted mt-3 max-w-md text-base">
        New essays and the occasional tool, 1–4 times a month. No spam, and you
        can unsubscribe anytime.
      </p>
    </div>

    <form
      data-newsletter
      class:list={[
        "max-w-xl",
        inline ? "mt-6 md:mt-0 md:w-full md:max-w-md md:flex-none" : "mt-7",
      ]}
    >
      <div class="flex flex-col gap-3 sm:flex-row">
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name="email_address"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="border-line bg-background text-ink placeholder:text-muted w-full min-w-0 flex-1 border px-4 py-3 font-sans text-base focus:outline-none"
        />
        <button
          type="submit"
          class="bg-ink text-background hover:bg-accent flex-none cursor-pointer px-6 py-3 font-sans text-sm font-semibold tracking-wide transition-colors disabled:opacity-60"
        >
          Subscribe
        </button>
      </div>
      <p
        data-newsletter-status
        aria-live="polite"
        class="mt-3 font-sans text-sm empty:hidden data-[state=error]:text-accent data-[state=ok]:text-accent data-[state=pending]:text-muted"
      >
      </p>
    </form>
  </div>
</section>

<script>
  const FORM_ID = "9685650";

  document.querySelectorAll("form[data-newsletter]").forEach((el) => {
    const form = el as HTMLFormElement;
    const status = form.querySelector<HTMLElement>("[data-newsletter-status]");
    const btn = form.querySelector<HTMLButtonElement>("button[type=submit]");
    const input = form.querySelector<HTMLInputElement>(
      "input[name=email_address]",
    );
    if (!status || !btn || !input) return;

    const set = (state: string, message: string) => {
      status.dataset.state = state;
      status.textContent = message;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!email) return;

      btn.disabled = true;
      set("pending", "Subscribing…");

      try {
        const res = await fetch(
          `https://app.kit.com/forms/${FORM_ID}/subscriptions`,
          {
            method: "POST",
            headers: {
              Accept: "application/json",
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: new URLSearchParams({ email_address: email }).toString(),
          },
        );
        const data = await res.json().catch(() => ({}));
        if (!res.ok || (data.errors && data.errors.length)) {
          throw new Error("subscribe failed");
        }
        form.reset();
        set("ok", "Almost there — check your inbox to confirm.");
      } catch {
        set("error", "That didn't go through. Please try again.");
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
