---
import Layout from "../../../layouts/Layout.astro";
import ReadTime from "../../../components/ReadTime.astro";

import TaxCrossLinks from "../../../components/TaxCrossLinks.astro";

import { coOccurringTax, getAllPosts, getTags } from "../../../lib/essays";
import { paginatedDescription, paginatedTitle } from "../../../lib/seo.ts";
import { breadcrumbList, collectionPage } from "../../../lib/schema.ts";

import type { GetStaticPaths, Page } from "astro";
import { type Post, type Tax } from "../../../types.ts";

export const getStaticPaths = (async ({ paginate }) => {
  const [posts, tags] = await Promise.all([getAllPosts(), getTags()]);

  return tags.flatMap((tag) => {
    const tagPosts = posts.filter((post) => post.tags.includes(tag.name));
    // Uncapped, unlike section→topics: a topic reaches only 1–4 sections.
    const sections = coOccurringTax(tagPosts, (post) => post.categories);
    return paginate(tagPosts, {
      params: { slug: tag.slug },
      props: { tag, sections },
      pageSize: 8,
    });
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<Post>;
  tag: Tax;
  sections: Tax[];
}
const { page, tag, sections } = Astro.props;

// No Featured block here — `sticky` is a section-level editorial signal, and
// promoting "the two newest" was meaningless. Topics just list everything.
const regularPosts = page.data;

const jsonLd = [
  breadcrumbList([{ name: "Topics", path: "/topic/" }, { name: tag.name }]),
  collectionPage({
    name: tag.name,
    description: tag.description,
    url: Astro.url.pathname,
    items: regularPosts,
    startIndex: page.start,
  }),
];
---

<Layout
  title={paginatedTitle(tag.name, page)}
  description={paginatedDescription(tag.description, page)}
  type="website"
  jsonLd={jsonLd}
>
  <div
    slot="intro"
    class="flex flex-col gap-4 pt-8 md:flex-row md:items-end md:justify-between md:gap-10"
  >
    <div class="space-y-4">
      <p class="label max-w-lg text-left">Topic</p>
      <h1 class="max-w-lg">
        {tag.name}
      </h1>
    </div>
    {
      tag.description && (
        <p class="lead max-w-lg text-left text-lg md:text-right">
          {tag.description}
        </p>
      )
    }
  </div>

  {
    regularPosts.length > 0 && (
      <section>
        <p class="meta mb-1 font-bold">All essays</p>
        {regularPosts.map((post) => {
          const postDate = new Date(post.date).toLocaleString("default", {
            day: "numeric",
            month: "short",
            year: "numeric",
          });

          // Meta leads on mobile, then moves beside the title from sm — hence
          // the order swap.
          return (
            <article class="border-line flex flex-col gap-3 border-t py-7 sm:flex-row sm:items-center sm:gap-10">
              <div class="meta flex items-center justify-between gap-4 sm:order-2 sm:flex-none sm:flex-col sm:items-end sm:gap-0 sm:text-right">
                <p class="text-accent">{postDate}</p>
                <ReadTime content={post.body} />
              </div>
              <div class="sm:order-1 sm:flex-1">
                <h3>
                  <a href={post.url} class="text-ink hover:text-accent">
                    {post.title}
                  </a>
                </h3>
                <p class="excerpt mt-3 text-base">{post.excerpt}</p>
              </div>
            </article>
          );
        })}
      </section>
    )
  }

  <nav
    class="meta flex items-center justify-center gap-6 pt-8 pb-10 font-medium"
  >
    {
      page.url.prev ? (
        <a href={page.url.prev} class="text-ink hover:text-accent">
          ← Newer
        </a>
      ) : undefined
    }
    <span class="text-muted">
      Page {page.currentPage} of {page.lastPage}
    </span>
    {
      page.url.next ? (
        <a href={page.url.next} class="text-ink hover:text-accent">
          Older →
        </a>
      ) : undefined
    }
  </nav>

  <TaxCrossLinks heading="Filed under" terms={sections} base="section" />
</Layout>
