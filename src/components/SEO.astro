---
import type { Post } from "../types.ts";
import { SITE_URL, SITE_TITLE, SITE_DESCRIPTION } from "../consts.ts";

const SITE_NAME = SITE_TITLE;
const AUTHOR_NAME = "Nicola Mustone";
const AUTHOR_URL = "https://nicolamustone.com";
const TWITTER_HANDLE = "@nicolamustone";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: "website" | "article" | "profile";
  article?: Post;
  noindex?: boolean;
  /** Extra schema.org nodes — build them with the helpers in lib/schema.ts. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  canonical = new URL(Astro.url.pathname, SITE_URL).href,
  ogImage,
  type = "website",
  article,
  noindex = false,
  jsonLd: extraJsonLd = [],
} = Astro.props;

const fullTitle = title === SITE_NAME ? SITE_NAME : `${title} — ${SITE_NAME}`;
const resolvedCanonical = article?.seo.canonical ?? canonical;
const resolvedOgImage = article?.seo.ogImage ?? ogImage;

const PERSON = {
  "@type": "Person",
  name: AUTHOR_NAME,
  url: AUTHOR_URL,
  sameAs: [
    "https://bsky.app/profile/nicolamustone.bsky.social",
    "https://github.com/SirDarcanos",
    "https://indieweb.social/@nicolamustone",
    "https://profiles.wordpress.org/nicolamustone/",
    "https://www.linkedin.com/in/nicolamustone/",
    "https://x.com/nicolamustone",
  ],
};

const jsonLd: Record<string, unknown>[] = [
  { "@context": "https://schema.org", ...PERSON },
];

// Homepage only. This node claims to describe the site as a whole, so emitting
// it on every type="website" page had every archive asserting it was the site.
// Archives use CollectionPage with an isPartOf reference instead.
if (Astro.url.pathname === "/") {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
  });
}

if (type === "profile") {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    name: fullTitle,
    url: resolvedCanonical,
    mainEntity: PERSON,
  });
}

if (article) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.title,
    description: article.seo.description,
    url: article.seo.canonical,
    datePublished: article.date,
    dateModified: article.modified,
    ...(article.featuredImage ? { image: article.featuredImage } : {}),
    author: PERSON,
    publisher: PERSON,
    mainEntityOfPage: article.seo.canonical,
  });
}

jsonLd.push(...extraJsonLd);
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />
{noindex && <meta name="robots" content="noindex, follow" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:site_name" content={SITE_NAME} />
{resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
<meta property="og:locale" content="en_US" />
{
  article && (
    <>
      <meta property="article:published_time" content={article.date} />
      <meta property="article:modified_time" content={article.modified} />
      <meta property="article:author" content={SITE_NAME} />
    </>
  )
}

{/* Twitter Card */}
<meta
  name="twitter:card"
  content={resolvedOgImage ? "summary_large_image" : "summary"}
/>
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
<meta name="twitter:site" content={TWITTER_HANDLE} />
<meta name="twitter:creator" content={TWITTER_HANDLE} />

{/* JSON-LD */}
{
  jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
